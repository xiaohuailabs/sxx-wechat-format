{
  "name": "渐变色块",
  "description": "渐变标题和引用背景，活泼吸睛，适合热门话题",
  "colors": {
    "primary": "#2d3436",
    "accent": "#6c5ce7",
    "background": "#ffffff",
    "blockquote_bg": "linear-gradient(135deg, #f5f0ff 0%, #eff8ff 100%)",
    "code_bg": "#f8f6ff",
    "hr_color": "#e0d4f7",
    "footnote_bg": "#f8f6ff"
  },
  "styles": {
    "h1": {
      "font_size": "22px",
      "font_weight": "bold",
      "color": "#ffffff",
      "text_align": "center",
      "margin_bottom": "24px",
      "line_height": "1.4",
      "background": "linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #00b894 100%)",
      "padding": "14px 20px",
      "border_radius": "10px"
    },
    "h2": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#ffffff",
      "background": "linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%)",
      "padding": "8px 16px",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "line_height": "1.4",
      "border_radius": "8px"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#6c5ce7",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "line_height": "1.4"
    },
    "p": {
      "font_size": "15px",
      "color": "#2d3436",
      "line_height": "1.8",
      "margin_bottom": "16px",
      "letter_spacing": "0.5px"
    },
    "blockquote": {
      "border_left": "4px solid #6c5ce7",
      "background": "linear-gradient(135deg, #f5f0ff 0%, #eff8ff 100%)",
      "padding": "14px 18px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 10px 10px 0",
      "font_size": "14px",
      "color": "#636e72",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#636e72",
      "line_height": "1.75",
      "margin_bottom": "0"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#6c5ce7"
    },
    "em": {
      "font_style": "italic",
      "color": "#636e72"
    },
    "a": {
      "color": "#6c5ce7",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "10px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "border": "none",
      "border_top": "2px solid #e0d4f7",
      "margin_top": "24px",
      "margin_bottom": "24px"
    },
    "code": {
      "background": "#f8f6ff",
      "padding": "2px 6px",
      "border_radius": "4px",
      "font_size": "13px",
      "color": "#6c5ce7",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "pre": {
      "background": "linear-gradient(135deg, #2d3436 0%, #1a1a2e 100%)",
      "color": "#dfe6e9",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#dfe6e9",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px"
    },
    "th": {
      "background": "linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%)",
      "padding": "10px 12px",
      "border": "1px solid #b8b0d8",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#ffffff"
    },
    "td": {
      "padding": "10px 12px",
      "border": "1px solid #e0d4f7",
      "color": "#2d3436"
    },
    "list_item_bullet": {
      "color": "#6c5ce7",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2d3436",
      "line_height": "1.8"
    },
    "list_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "2px solid #e0d4f7"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#6c5ce7",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "linear-gradient(135deg, #f5f0ff 0%, #eff8ff 100%)",
      "border_left": "4px solid #6c5ce7",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 10px 10px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#6c5ce7",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#636e72",
      "line_height": "1.75"
    },
    "code_block": {
      "background": "linear-gradient(135deg, #2d3436 0%, #1a1a2e 100%)",
      "border_radius": "10px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "linear-gradient(135deg, #2d3436 0%, #1a1a2e 100%)"
    }
  },
  "dark_mode": {
    "h1": {
      "bgcolor": "#5a4cc7",
      "color": "#ffffff"
    },
    "h2": {
      "bgcolor": "#5a4cc7",
      "color": "#ffffff"
    },
    "pre": {
      "bgcolor": "#1a1a2e",
      "color": "#dfe6e9"
    },
    "pre_code": {
      "color": "#dfe6e9"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#a090ff"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#5a4cc7",
      "color": "#ffffff"
    },
    "callout": {
      "bgcolor": "rgba(108,92,231,0.1)"
    }
  }
}