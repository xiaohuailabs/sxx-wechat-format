{
  "name": "大留白杂志",
  "description": "超大行距，极致留白，品质感长文阅读",
  "colors": {
    "primary": "#333333",
    "accent": "#1a1a1a",
    "background": "#ffffff",
    "blockquote_bg": "#f9f9f9",
    "code_bg": "#f5f5f5",
    "hr_color": "#e0e0e0",
    "footnote_bg": "#f9f9f9"
  },
  "styles": {
    "h1": {
      "font_size": "26px",
      "font_weight": "900",
      "color": "#1a1a1a",
      "text_align": "center",
      "margin_bottom": "36px",
      "margin_top": "20px",
      "line_height": "1.5",
      "letter_spacing": "3px"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "bold",
      "color": "#1a1a1a",
      "margin_top": "48px",
      "margin_bottom": "24px",
      "line_height": "1.5",
      "text_align": "center",
      "letter_spacing": "2px"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "bold",
      "color": "#333333",
      "margin_top": "36px",
      "margin_bottom": "18px",
      "line_height": "1.5",
      "letter_spacing": "1px"
    },
    "p": {
      "font_size": "16px",
      "color": "#333333",
      "line_height": "2.2",
      "margin_bottom": "24px",
      "letter_spacing": "0.8px"
    },
    "blockquote": {
      "border_left": "2px solid #1a1a1a",
      "background": "#f9f9f9",
      "padding": "20px 24px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "border_radius": "0",
      "font_size": "15px",
      "color": "#555555",
      "line_height": "2.0"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#555555",
      "line_height": "2.0",
      "margin_bottom": "0"
    },
    "strong": {
      "font_weight": "900",
      "color": "#1a1a1a"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#1a1a1a",
      "text_decoration": "underline"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "0",
      "margin_top": "28px",
      "margin_bottom": "28px"
    },
    "hr": {
      "border": "none",
      "border_top": "1px solid #e0e0e0",
      "margin_top": "40px",
      "margin_bottom": "40px",
      "max_width": "30%",
      "margin_left": "auto",
      "margin_right": "auto"
    },
    "code": {
      "background": "#f5f5f5",
      "padding": "2px 8px",
      "border_radius": "2px",
      "font_size": "14px",
      "color": "#333333",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "pre": {
      "background": "#1a1a1a",
      "color": "#e8e8e8",
      "padding": "20px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.6",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#e8e8e8",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_size": "14px"
    },
    "th": {
      "background": "#f9f9f9",
      "padding": "14px 16px",
      "border": "1px solid #e0e0e0",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#1a1a1a",
      "letter_spacing": "1px"
    },
    "td": {
      "padding": "14px 16px",
      "border": "1px solid #e0e0e0",
      "color": "#333333"
    },
    "list_item_bullet": {
      "color": "#1a1a1a",
      "margin_right": "12px",
      "font_weight": "normal"
    },
    "list_item_text": {
      "font_size": "16px",
      "color": "#333333",
      "line_height": "2.2"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "12px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "48px",
      "padding_top": "24px",
      "border_top": "1px solid #e0e0e0"
    },
    "footnote_title": {
      "font_size": "13px",
      "font_weight": "bold",
      "color": "#aaaaaa",
      "margin_bottom": "14px",
      "letter_spacing": "2px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#aaaaaa",
      "margin_bottom": "8px",
      "line_height": "1.7",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#1a1a1a",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f9f9f9",
      "border_left": "2px solid #1a1a1a",
      "padding": "20px 24px",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "border_radius": "0"
    },
    "callout_title": {
      "font_weight": "900",
      "color": "#1a1a1a",
      "margin_bottom": "10px",
      "font_size": "16px",
      "letter_spacing": "1px"
    },
    "callout_content": {
      "font_size": "15px",
      "color": "#555555",
      "line_height": "2.0"
    },
    "code_block": {
      "background": "#1a1a1a",
      "border_radius": "0",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#1a1a1a"
    }
  },
  "dark_mode": {
    "pre": {
      "bgcolor": "#1a1a1a",
      "color": "#e8e8e8"
    },
    "pre_code": {
      "color": "#e8e8e8"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#d4d4d4"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(255,255,255,0.05)"
    }
  }
}