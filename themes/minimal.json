{
  "name": "极简",
  "description": "灰色系，最大留白，适合知识分享、教程",
  "colors": {
    "primary": "#444444",
    "accent": "#888888",
    "background": "#ffffff",
    "blockquote_bg": "#f9f9f9",
    "code_bg": "#f5f5f5",
    "hr_color": "#eeeeee",
    "footnote_bg": "#f9f9f9"
  },
  "styles": {
    "h1": {
      "font_size": "22px",
      "font_weight": "bold",
      "color": "#222222",
      "text_align": "center",
      "margin_bottom": "24px",
      "line_height": "1.4"
    },
    "h2": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#222222",
      "border_bottom": "1px solid #eeeeee",
      "padding_bottom": "8px",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "line_height": "1.4"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#333333",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "line_height": "1.4"
    },
    "p": {
      "font_size": "15px",
      "color": "#444444",
      "line_height": "1.8",
      "margin_bottom": "16px",
      "letter_spacing": "0.5px"
    },
    "blockquote": {
      "border_left": "3px solid #cccccc",
      "background": "#f9f9f9",
      "padding": "12px 16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 4px 4px 0",
      "font_size": "14px",
      "color": "#666666",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#666666",
      "line_height": "1.75",
      "margin_bottom": "0"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#222222"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#555555",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "4px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "border": "none",
      "border_top": "1px solid #eeeeee",
      "margin_top": "28px",
      "margin_bottom": "28px"
    },
    "code": {
      "background": "#f5f5f5",
      "padding": "2px 6px",
      "border_radius": "3px",
      "font_size": "13px",
      "color": "#555555",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "pre": {
      "background": "#2d2d2d",
      "color": "#e0e0e0",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#e0e0e0",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px"
    },
    "th": {
      "background": "#f9f9f9",
      "padding": "10px 12px",
      "border": "1px solid #eeeeee",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#333333"
    },
    "td": {
      "padding": "10px 12px",
      "border": "1px solid #eeeeee",
      "color": "#444444"
    },
    "list_item_bullet": {
      "color": "#888888",
      "margin_right": "8px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#444444",
      "line_height": "1.8"
    },
    "list_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px solid #eeeeee"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#aaaaaa",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#aaaaaa",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#888888",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f9f9f9",
      "border_left": "3px solid #cccccc",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 4px 4px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#555555",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#666666",
      "line_height": "1.75"
    },
    "code_block": {
      "background": "#2d2d2d",
      "border_radius": "4px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#2d2d2d"
    }
  },
  "dark_mode": {
    "pre": {
      "bgcolor": "#2d2d2d",
      "color": "#e0e0e0"
    },
    "pre_code": {
      "color": "#e0e0e0"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#b0b0b0"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(255,255,255,0.05)"
    }
  }
}