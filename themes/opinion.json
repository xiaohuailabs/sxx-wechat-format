{
  "name": "锐评",
  "description": "紫色强调，犀利感，适合辣评、争议话题",
  "colors": {
    "primary": "#2c2c3a",
    "accent": "#8e44ad",
    "background": "#ffffff",
    "blockquote_bg": "#f8f0fc",
    "code_bg": "#f8f4fa",
    "hr_color": "#dcc8e8",
    "footnote_bg": "#f8f0fc"
  },
  "styles": {
    "h1": {
      "font_size": "23px",
      "font_weight": "bold",
      "color": "#1a1a2a",
      "text_align": "center",
      "margin_bottom": "24px",
      "line_height": "1.4"
    },
    "h2": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#1a1a2a",
      "border_left": "5px solid #8e44ad",
      "padding_left": "14px",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "line_height": "1.4"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#8e44ad",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "line_height": "1.4"
    },
    "p": {
      "font_size": "15px",
      "color": "#2c2c3a",
      "line_height": "1.8",
      "margin_bottom": "16px",
      "letter_spacing": "0.5px"
    },
    "blockquote": {
      "border_left": "4px solid #8e44ad",
      "background": "#f8f0fc",
      "padding": "14px 18px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 8px 8px 0",
      "font_size": "15px",
      "color": "#5a4a66",
      "line_height": "1.8",
      "font_weight": "bold"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#5a4a66",
      "line_height": "1.8",
      "margin_bottom": "0"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#8e44ad"
    },
    "em": {
      "font_style": "italic",
      "color": "#6a5a7a"
    },
    "a": {
      "color": "#8e44ad",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "border": "none",
      "border_top": "2px solid #dcc8e8",
      "margin_top": "28px",
      "margin_bottom": "28px"
    },
    "code": {
      "background": "#f8f4fa",
      "padding": "2px 6px",
      "border_radius": "4px",
      "font_size": "13px",
      "color": "#8e44ad",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "pre": {
      "background": "#2a1a2e",
      "color": "#e8d0f0",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#e8d0f0",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px"
    },
    "th": {
      "background": "#8e44ad",
      "padding": "10px 12px",
      "border": "1px solid #7d3c98",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#ffffff"
    },
    "td": {
      "padding": "10px 12px",
      "border": "1px solid #dcc8e8",
      "color": "#2c2c3a"
    },
    "list_item_bullet": {
      "color": "#8e44ad",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2c2c3a",
      "line_height": "1.8"
    },
    "list_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "2px solid #dcc8e8"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#8e44ad",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f8f0fc",
      "border_left": "5px solid #8e44ad",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 8px 8px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#8e44ad",
      "margin_bottom": "8px",
      "font_size": "16px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#5a4a66",
      "line_height": "1.8"
    },
    "code_block": {
      "background": "#2a1a2e",
      "border_radius": "8px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#2a1a2e"
    }
  },
  "dark_mode": {
    "pre": {
      "bgcolor": "#2a1a2e",
      "color": "#e8d0f0"
    },
    "pre_code": {
      "color": "#e8d0f0"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#b060d0"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#6e3488",
      "color": "#ffffff"
    },
    "callout": {
      "bgcolor": "rgba(142,68,173,0.1)"
    }
  }
}