{
  "name": "复古打字机",
  "description": "等宽字体感，牛皮纸色调，适合怀旧、文化类内容",
  "colors": {
    "primary": "#3c3022",
    "accent": "#8b4513",
    "background": "#fdf6e3",
    "blockquote_bg": "#f5edd6",
    "code_bg": "#f0e8d0",
    "hr_color": "#d4c5a0",
    "footnote_bg": "#f5edd6"
  },
  "styles": {
    "wrapper": {
      "background": "#fdf6e3",
      "padding": "20px",
      "color": "#3c3022"
    },
    "h1": {
      "font_size": "22px",
      "font_weight": "bold",
      "color": "#2a1f10",
      "text_align": "center",
      "margin_bottom": "24px",
      "line_height": "1.5",
      "letter_spacing": "4px",
      "border_bottom": "2px double #8b4513",
      "padding_bottom": "14px"
    },
    "h2": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#2a1f10",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "line_height": "1.5",
      "letter_spacing": "2px",
      "border_bottom": "1px solid #d4c5a0",
      "padding_bottom": "8px"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#5a4020",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "line_height": "1.5",
      "letter_spacing": "1px"
    },
    "p": {
      "font_size": "15px",
      "color": "#3c3022",
      "line_height": "1.9",
      "margin_bottom": "16px",
      "letter_spacing": "0.5px"
    },
    "blockquote": {
      "border_left": "3px solid #8b4513",
      "background": "#f5edd6",
      "padding": "14px 18px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0",
      "font_size": "14px",
      "color": "#6a5a40",
      "line_height": "1.8",
      "font_style": "italic"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#6a5a40",
      "line_height": "1.8",
      "margin_bottom": "0"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#8b4513"
    },
    "em": {
      "font_style": "italic",
      "color": "#6a5a40"
    },
    "a": {
      "color": "#8b4513",
      "text_decoration": "underline"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "2px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "border": "2px solid #d4c5a0"
    },
    "hr": {
      "border": "none",
      "border_top": "2px double #d4c5a0",
      "margin_top": "28px",
      "margin_bottom": "28px"
    },
    "code": {
      "background": "#f0e8d0",
      "padding": "2px 6px",
      "border_radius": "2px",
      "font_size": "13px",
      "color": "#8b4513",
      "font_family": "Courier New, Courier, monospace"
    },
    "pre": {
      "background": "#2a1f10",
      "color": "#d4c5a0",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.5",
      "font_family": "Courier New, Courier, monospace",
      "border": "1px solid #5a4020",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#d4c5a0",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px"
    },
    "th": {
      "background": "#f0e8d0",
      "padding": "10px 14px",
      "border": "1px solid #d4c5a0",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#2a1f10"
    },
    "td": {
      "padding": "10px 14px",
      "border": "1px solid #d4c5a0",
      "color": "#3c3022"
    },
    "list_item_bullet": {
      "color": "#8b4513",
      "margin_right": "10px",
      "font_weight": "normal"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#3c3022",
      "line_height": "1.9"
    },
    "list_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "2px double #d4c5a0"
    },
    "footnote_title": {
      "font_size": "13px",
      "font_weight": "bold",
      "color": "#a09070",
      "margin_bottom": "12px",
      "letter_spacing": "2px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#a09070",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#8b4513",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f5edd6",
      "border_left": "3px solid #8b4513",
      "padding": "16px 18px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#8b4513",
      "margin_bottom": "8px",
      "font_size": "15px",
      "letter_spacing": "1px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#6a5a40",
      "line_height": "1.8"
    },
    "code_block": {
      "background": "#2a1f10",
      "border_radius": "2px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#2a1f10"
    }
  },
  "dark_mode": {
    "wrapper": {
      "bgcolor": "#1e1e1e"
    },
    "pre": {
      "bgcolor": "#2a1f10",
      "color": "#d4c5a0"
    },
    "pre_code": {
      "color": "#d4c5a0"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#c4842a"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(139,69,19,0.1)"
    }
  }
}