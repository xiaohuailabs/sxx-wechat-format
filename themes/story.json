{
  "name": "杂志叙事",
  "description": "棕褐色调，书卷气质，适合人物故事、深度特稿",
  "colors": {
    "primary": "#3a3226",
    "accent": "#8b6914",
    "background": "#ffffff",
    "blockquote_bg": "#faf6ee",
    "code_bg": "#f7f3eb",
    "hr_color": "#d9cdb5",
    "footnote_bg": "#faf6ee"
  },
  "styles": {
    "h1": {
      "font_size": "24px",
      "font_weight": "bold",
      "color": "#2a2118",
      "text_align": "center",
      "margin_bottom": "28px",
      "line_height": "1.5",
      "letter_spacing": "2px"
    },
    "h2": {
      "font_size": "19px",
      "font_weight": "bold",
      "color": "#2a2118",
      "margin_top": "36px",
      "margin_bottom": "18px",
      "line_height": "1.5",
      "text_align": "center",
      "letter_spacing": "1px"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#5a4a36",
      "margin_top": "28px",
      "margin_bottom": "14px",
      "line_height": "1.5"
    },
    "p": {
      "font_size": "15px",
      "color": "#3a3226",
      "line_height": "2.0",
      "margin_bottom": "18px",
      "letter_spacing": "0.5px",
      "text_indent": "2em"
    },
    "blockquote": {
      "border_left": "3px solid #8b6914",
      "background": "#faf6ee",
      "padding": "14px 18px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "border_radius": "0 8px 8px 0",
      "font_size": "14px",
      "color": "#6a5a46",
      "line_height": "1.85",
      "font_style": "italic"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#6a5a46",
      "line_height": "1.85",
      "margin_bottom": "0",
      "text_indent": "0"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#8b6914"
    },
    "em": {
      "font_style": "italic",
      "color": "#6a5a46"
    },
    "a": {
      "color": "#8b6914",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "4px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "border": "1px solid #e8dcc8"
    },
    "hr": {
      "border": "none",
      "border_top": "1px solid #d9cdb5",
      "margin_top": "32px",
      "margin_bottom": "32px",
      "max_width": "40%",
      "margin_left": "auto",
      "margin_right": "auto"
    },
    "code": {
      "background": "#f7f3eb",
      "padding": "2px 6px",
      "border_radius": "3px",
      "font_size": "13px",
      "color": "#8b6914",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "pre": {
      "background": "#2a2118",
      "color": "#e8dcc8",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#e8dcc8",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "14px"
    },
    "th": {
      "background": "#faf6ee",
      "padding": "10px 14px",
      "border": "1px solid #d9cdb5",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#3a3226"
    },
    "td": {
      "padding": "10px 14px",
      "border": "1px solid #d9cdb5",
      "color": "#3a3226"
    },
    "list_item_bullet": {
      "color": "#8b6914",
      "margin_right": "10px",
      "font_weight": "normal"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#3a3226",
      "line_height": "2.0"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "10px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "36px",
      "padding_top": "18px",
      "border_top": "1px solid #d9cdb5"
    },
    "footnote_title": {
      "font_size": "13px",
      "font_weight": "bold",
      "color": "#a09080",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#a09080",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#8b6914",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#faf6ee",
      "border_left": "3px solid #8b6914",
      "padding": "16px 18px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "border_radius": "0 8px 8px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#8b6914",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#6a5a46",
      "line_height": "1.85"
    },
    "code_block": {
      "background": "#2a2118",
      "border_radius": "6px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#2a2118"
    }
  },
  "dark_mode": {
    "pre": {
      "bgcolor": "#2a2118",
      "color": "#e8dcc8"
    },
    "pre_code": {
      "color": "#e8dcc8"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#c4a030"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(139,105,20,0.1)"
    }
  }
}