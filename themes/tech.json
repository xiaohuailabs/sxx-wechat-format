{
  "name": "科技",
  "description": "蓝色强调，冷色调，适合技术教程、AI 资讯",
  "colors": {
    "primary": "#2c3e50",
    "accent": "#0071e3",
    "background": "#ffffff",
    "blockquote_bg": "#f0f7ff",
    "code_bg": "#f5f7fa",
    "hr_color": "#dce3eb",
    "footnote_bg": "#f5f7fa"
  },
  "styles": {
    "h1": {
      "font_size": "22px",
      "font_weight": "bold",
      "color": "#1a1a2e",
      "text_align": "center",
      "margin_bottom": "24px",
      "line_height": "1.4"
    },
    "h2": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#1a1a2e",
      "border_bottom": "2px solid #0071e3",
      "padding_bottom": "8px",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "line_height": "1.4"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#2c3e50",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "line_height": "1.4"
    },
    "p": {
      "font_size": "15px",
      "color": "#2c3e50",
      "line_height": "1.8",
      "margin_bottom": "16px",
      "letter_spacing": "0.5px"
    },
    "blockquote": {
      "border_left": "4px solid #0071e3",
      "background": "#f0f7ff",
      "padding": "12px 16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 8px 8px 0",
      "font_size": "14px",
      "color": "#5a6a7a",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#5a6a7a",
      "line_height": "1.75",
      "margin_bottom": "0"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#0071e3"
    },
    "em": {
      "font_style": "italic",
      "color": "#5a6a7a"
    },
    "a": {
      "color": "#0071e3",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "border": "none",
      "border_top": "1px solid #dce3eb",
      "margin_top": "24px",
      "margin_bottom": "24px"
    },
    "code": {
      "background": "#f5f7fa",
      "padding": "2px 6px",
      "border_radius": "4px",
      "font_size": "13px",
      "color": "#0071e3",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "pre": {
      "background": "#1e2d3d",
      "color": "#e0e6ed",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#e0e6ed",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px"
    },
    "th": {
      "background": "#f0f7ff",
      "padding": "10px 12px",
      "border": "1px solid #dce3eb",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#2c3e50"
    },
    "td": {
      "padding": "10px 12px",
      "border": "1px solid #dce3eb",
      "color": "#2c3e50"
    },
    "list_item_bullet": {
      "color": "#0071e3",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2c3e50",
      "line_height": "1.8"
    },
    "list_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px solid #dce3eb"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#0071e3",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f0f7ff",
      "border_left": "4px solid #0071e3",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 8px 8px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#0071e3",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#5a6a7a",
      "line_height": "1.75"
    },
    "code_block": {
      "background": "#1e2d3d",
      "border_radius": "8px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#1e2d3d"
    }
  },
  "dark_mode": {
    "pre": {
      "bgcolor": "#1e2d3d",
      "color": "#e0e6ed"
    },
    "pre_code": {
      "color": "#e0e6ed"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#4d9fff"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#262626",
      "color": "#4d9fff"
    },
    "callout": {
      "bgcolor": "rgba(0,113,227,0.1)"
    }
  }
}