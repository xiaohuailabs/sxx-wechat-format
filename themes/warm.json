{
  "name": "温暖",
  "description": "橘色强调，暖色调，适合故事、生活类",
  "colors": {
    "primary": "#3d3d3d",
    "accent": "#e07a5f",
    "background": "#ffffff",
    "blockquote_bg": "#fef6f3",
    "code_bg": "#fef6f3",
    "hr_color": "#f0d9d0",
    "footnote_bg": "#fef6f3"
  },
  "styles": {
    "h1": {
      "font_size": "22px",
      "font_weight": "bold",
      "color": "#2d2d2d",
      "text_align": "center",
      "margin_bottom": "24px",
      "line_height": "1.4"
    },
    "h2": {
      "font_size": "18px",
      "font_weight": "bold",
      "color": "#2d2d2d",
      "border_bottom": "1px solid #f0d9d0",
      "padding_bottom": "8px",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "line_height": "1.4"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "bold",
      "color": "#3d3d3d",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "line_height": "1.4"
    },
    "p": {
      "font_size": "15px",
      "color": "#3d3d3d",
      "line_height": "1.8",
      "margin_bottom": "16px",
      "letter_spacing": "0.5px"
    },
    "blockquote": {
      "border_left": "4px solid #e07a5f",
      "background": "#fef6f3",
      "padding": "12px 16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 8px 8px 0",
      "font_size": "14px",
      "color": "#7a6a63",
      "line_height": "1.75"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#7a6a63",
      "line_height": "1.75",
      "margin_bottom": "0"
    },
    "strong": {
      "font_weight": "bold",
      "color": "#e07a5f"
    },
    "em": {
      "font_style": "italic",
      "color": "#7a6a63"
    },
    "a": {
      "color": "#e07a5f",
      "text_decoration": "none"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "border": "none",
      "border_top": "1px solid #f0d9d0",
      "margin_top": "24px",
      "margin_bottom": "24px"
    },
    "code": {
      "background": "#fef6f3",
      "padding": "2px 6px",
      "border_radius": "4px",
      "font_size": "13px",
      "color": "#e07a5f",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "pre": {
      "background": "#3d2d2d",
      "color": "#f0e0d8",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#f0e0d8",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px"
    },
    "th": {
      "background": "#fef6f3",
      "padding": "10px 12px",
      "border": "1px solid #f0d9d0",
      "text_align": "left",
      "font_weight": "bold",
      "color": "#3d3d3d"
    },
    "td": {
      "padding": "10px 12px",
      "border": "1px solid #f0d9d0",
      "color": "#3d3d3d"
    },
    "list_item_bullet": {
      "color": "#e07a5f",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#3d3d3d",
      "line_height": "1.8"
    },
    "list_wrapper": {
      "margin_top": "12px",
      "margin_bottom": "12px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px solid #f0d9d0"
    },
    "footnote_title": {
      "font_size": "14px",
      "font_weight": "bold",
      "color": "#999999",
      "margin_bottom": "12px"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all"
    },
    "footnote_sup": {
      "font_size": "12px",
      "color": "#e07a5f",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#fef6f3",
      "border_left": "4px solid #e07a5f",
      "padding": "16px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 8px 8px 0"
    },
    "callout_title": {
      "font_weight": "bold",
      "color": "#e07a5f",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#7a6a63",
      "line_height": "1.75"
    },
    "code_block": {
      "background": "#3d2d2d",
      "border_radius": "8px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "36px",
      "padding": "0 12px",
      "background": "#3d2d2d"
    }
  },
  "dark_mode": {
    "pre": {
      "bgcolor": "#3d2d2d",
      "color": "#f0e0d8"
    },
    "pre_code": {
      "color": "#f0e0d8"
    },
    "code": {
      "bgcolor": "#2a2a2a",
      "color": "#e8956f"
    },
    "blockquote": {
      "bgcolor": "rgba(255,255,255,0.05)"
    },
    "th": {
      "bgcolor": "#262626"
    },
    "callout": {
      "bgcolor": "rgba(224,122,95,0.1)"
    }
  }
}